# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_CLIENT_IDENTITY=bolaji

# App
PUBLIC_BASE_URL=https://dialer.example.com
PORT=3001
TOKEN_TTL_SECONDS=3600

# Single-user login (form-based session auth; leave BASIC_AUTH_USER blank to
# disable auth entirely, e.g. if you front it with Cloudflare Access)
BASIC_AUTH_USER=you@example.com
BASIC_AUTH_PASSWORD=change_me_to_a_strong_password

# Signs the session cookie. Set a long random value so logins survive restarts:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Cloudflare Tunnel token for this dialer's OWN dedicated tunnel.
# Create the tunnel in Zero Trust > Networks > Tunnels (type: Docker) and paste
# its token here. Consumed by the cloudflared service as TUNNEL_TOKEN.
CLOUDFLARE_TUNNEL_TOKEN=
